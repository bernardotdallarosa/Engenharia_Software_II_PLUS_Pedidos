# ─── Ports ───────────────────────────────────────────────────────────────────
MS_AUTH_PORT=3001
MFE_AUTH_PORT=4001
MS_PED_PORT=3007
MFE_PED_PORT=4007
SHELL_PORT=3000

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ─── AWS / Ministack ──────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT=http://localhost:4566

# Fila SQS para eventos de pedidos (preenchida após terraform apply — ver output order_events_queue_url)
ORDER_EVENTS_QUEUE_URL=

# ─── RDS (credenciais alinhadas com o Terraform) ──────────────────────────────
# plus-ms-auth  → terraform/rds.env     (rds_address)  + DB_NAME=plus_auth
# plus-ms-ped   → terraform/rds-ped.env (rds_ped_address) + DB_NAME=plus_ped (fixo no compose)
# Gerados por make setup / scripts/write-rds-env.* após terraform apply.
DB_HOST=localhost
DB_PORT=5432
DB_USER=plus
DB_PASSWORD=plus_secret
DB_NAME=plus_auth

# ─── MFE Auth (browser → plus-ms-auth) ────────────────────────────────────────
# O "make setup" grava VITE_MS_AUTH_URL com o URL do API Gateway (Terraform).
# O docker compose faz build do plus-mfe-auth com VITE_MS_AUTH_BROWSER (3001 directo).
VITE_MS_AUTH_URL=http://localhost:4566/restapis/placeholder-api-id/v1/_user_request_
VITE_MS_AUTH_BROWSER=http://localhost:3001

# ─── Shell (Module Federation) ────────────────────────────────────────────────
MFE_AUTH_URL=http://localhost:4001/assets/remoteEntry.js
MFE_PED_URL=http://localhost:4007/assets/remoteEntry.js

# ─── MFE Pedidos (browser → plus-ms-ped) ──────────────────────────────────────
VITE_MS_PED_URL=http://localhost:3007
