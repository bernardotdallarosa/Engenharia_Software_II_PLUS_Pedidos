# ─── Ports ───────────────────────────────────────────────────────────────────
MS_AUTH_PORT=3001
MFE_AUTH_PORT=4001
SHELL_PORT=3000

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ─── AWS / Ministack (LocalStack) ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT=http://localhost:4566

# ─── RDS (credenciais alinhadas com o Terraform) ───────────────────────────────
# O plus-ms-auth lê DB_HOST/DB_PORT de terraform/rds.env (gerado por scripts/write-rds-env após apply).
# Para npm run dev no PC: use os mesmos valores (terraform output -raw rds_address / rds_port).
DB_HOST=localhost
DB_PORT=5432
DB_USER=plus
DB_PASSWORD=plus_secret
DB_NAME=plus_auth

# ─── MFE (browser → plus-ms-auth) ─────────────────────────────────────────────
# O "make setup" grava VITE_MS_AUTH_URL com o URL do API Gateway (Terraform) — serve de referência.
# O docker compose faz o build do plus-mfe-auth com VITE_MS_AUTH_BROWSER (por omissão 3001), porque
# o browser precisa de CORS e o gateway em LocalStack (4566) costuma não devolver headers corretos.
# Para testar o MFE contra o gateway no browser, defina explicitamente, ex.:
#   VITE_MS_AUTH_BROWSER=http://localhost:4566/restapis/<api-id>/v1/_user_request_
VITE_MS_AUTH_URL=http://localhost:4566/restapis/placeholder-api-id/v1/_user_request_
VITE_MS_AUTH_BROWSER=http://localhost:3001

# ─── Shell (Module Federation) ────────────────────────────────────────────────
# Build-arg do plus-shell: URL absoluto do remoteEntry.js do MFE (Vite 5 → /assets/).
# MFE_AUTH_URL=http://localhost:4001/assets/remoteEntry.js
